    },
    "seo_description": {
      "type": "text"
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "sections.hero",
        "sections.text-block",
        "sections.image-text",
        "sections.cards-grid",
        "sections.cta-banner",
        "sections.row"
