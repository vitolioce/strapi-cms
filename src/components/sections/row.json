{
  "collectionName": "components_sections_rows",
  "info": {
    "displayName": "Row",
    "icon": "layout"
  },
  "attributes": {
    "columns_layout": {
      "type": "enumeration",
      "enum": [
        "1-col",
        "2-col-equal",
        "2-col-1-3",
        "2-col-2-3",
        "3-col-equal",
        "4-col-equal"
      ],
      "default": "2-col-equal"
    },
    "background_color": {
      "type": "string",
      "default": "#ffffff"
    },
    "padding_y": {
      "type": "enumeration",
      "enum": ["none", "small", "medium", "large"],
      "default": "medium"
    },
    "columns": {
      "type": "component",
      "repeatable": true,
      "component": "elements.column"
    }
  }
}
